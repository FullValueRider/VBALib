   [ TestCase ] '("Collection")
    Private Sub Test85_ToCollectionFromStack()
        ''On Error GoTo TestFail
        
        'Arrange:
        Dim myExpected  As Collection
        Set myExpected = New Collection
        myExpected.Add 10
        myExpected.Add 20
        myExpected.Add 30
        myExpected.Add 40
        
        
        
        Dim myResult As Collection
        
        
        Dim myIterable As Stack
        ' To allow sequence equals we need to push onto the stack in reverse order
        ' because the last item pushed is item 1 which is significant
        ' when using the for each loop to transfer values
         Set myIterable = New Stack
         myIterable.Push 40
         myIterable.Push 30
         myIterable.Push 20
         myIterable.Push 10
        
        'Act:
         Set myResult = Types.Iterable.ToCollection(10, 20, 30, 40)
    
        'Assert:
        
        'cOMPARE ITEM BY TEM AS COLLECTIONS DON'T HAVE A TO ARRAY METHOD
         Assert.Exact.AreEqual myExpected.Item(1), myResult.Item(1), CurrentProcedureName
         Assert.Exact.AreEqual myExpected.Item(2), myResult.Item(2), CurrentProcedureName
         Assert.Exact.AreEqual myExpected.Item(3), myResult.Item(3), CurrentProcedureName
         Assert.Exact.AreEqual myExpected.Item(4), myResult.Item(4), CurrentProcedureName

    TestExit:
        Exit Sub
    TestFail:
