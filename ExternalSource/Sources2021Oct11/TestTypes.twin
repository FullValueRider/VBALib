        Dim myIterable As ArrayList
        Set myIterable = New ArrayList
        With myIterable
        
            .Add 10
            .Add 20
            .Add 30
            .Add 40
            .Add 50
            
        End With
        'Act:
        
        myResult = Types.Iterable.HasItems(myIterable)
    
        'Assert:
