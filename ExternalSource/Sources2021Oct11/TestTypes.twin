#Region "FirstIndex"

   [ TestCase ] '("Array")
    Private Sub Test31_FirstIndexTryGetFromEmptyArray()
        ''On Error GoTo TestFail
        
        'Arrange:
        Dim myExpectedStatus  As Boolean
        myExpectedStatus = False
        
        Dim myExpected As Long
        myExpected = -1
        
        '@Ignore IntegerDataType
        Dim myIterable() As Integer
        
        Dim myResultStatus As Boolean
        Dim myResult As Long
        
        'Act:
        '@Ignore ImplicitDefaultMemberAccess
        myResultStatus = Types.Iterable.TryFirstIndex(myIterable, myResult)
    
        'Assert:
        Assert.Exact.AreEqual myExpectedStatus, myResultStatus, myPlace & CurrentProcedureName & ":Status"
        Assert.Exact.AreEqual myExpected, myResult, "Value"

    TestExit:
        Exit Sub
        
    TestFail:
        Debug.Print myPlace & CurrentProcedureName & "   raised an error: #" & Err.Number & " - " & Err.Description
        Resume TestExit
        
    End Sub

   [ TestCase ] '("Array")
    Private Sub Test32_FirstIndexTryGetFromArray()
        ''On Error GoTo TestFail
       ' If Assert Is Nothing Then Set Assert = New AssertClass
        'Arrange:
        Dim myExpectedStatus  As Boolean
        myExpectedStatus = True
        
        Dim myExpected As Long
        myExpected = 10&
        '@Ignore IntegerDataType
        Dim myIterable(10 To 15) As Integer
        
        
        Dim myResult As Long
        Dim myResultStatus As Boolean
        
        'Act:
